{
	"root": true,

	"extends": "@ljharb",

	"rules": {
		"func-name-matching": 0,
		"func-style": [2, "declaration"],
		"id-length": [2, { "min": 1, "max": 24, "properties": "never" }],
		"new-cap": [2, {
			"capIsNewExceptions": [
				"GetMethod",
				"OrdinaryToPrimitive",
			],
		}],
		"no-extra-parens": 0,
	},

	"overrides": [
		{
			"files": "test/**",
			"rules": {
				"max-lines-per-function": 0,
			},
		}
	],
}
